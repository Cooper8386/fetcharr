# Copy to /mnt/user/scripts/.cleanup.env and chmod 600
# IMPORTANT: rotate the old Sonarr/Radarr API keys before populating these.

SONARR_API_KEY=replace_me
RADARR_API_KEY=replace_me

SONARR_URL=http://192.168.5.61:8989
RADARR_URL=http://192.168.5.61:7878

# Optional Healthchecks.io ping URL
# HEALTHCHECK_URL=https://hc-ping.com/REPLACE-ME

# Optional overrides
# RETENTION_MINUTES=1440
# LOG_DIR=/mnt/user/scripts/logs/history
# DRY_RUN=1
